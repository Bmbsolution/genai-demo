# Copy to .env for local development. NEVER put real secrets here (rule S7).
# Values below are local-dev defaults only.

SERVICECAT_DATABASE_URL=postgresql+asyncpg://servicecat:servicecat@localhost:5440/servicecat
SERVICECAT_REDIS_URL=redis://localhost:6380/0
SERVICECAT_ENVIRONMENT=local

# JWT signing keys (RS256) are introduced in the auth issue (F-02).
# Generate a local keypair and point these at the files; never commit real keys.
# SERVICECAT_JWT_PRIVATE_KEY_PATH=./secrets/jwt_private.pem
# SERVICECAT_JWT_PUBLIC_KEY_PATH=./secrets/jwt_public.pem
